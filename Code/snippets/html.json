{
  "picture": {
    "prefix": "pic",
    "body": [
      "<picture>",
      "  <source srcset=\"$1\" media=\"(min-width: 768px)\">",
      "  <img src=\"$1\" alt=\"$2\" width=\"\" height=\"\" ${3|loading=\"lazy\" decoding=\"async\"|}$4",
      "</picture>"
    ],
    "description": "picture"
  },

  "img": {
    "prefix": "img",
    "body": [
      "<img src=\"$1\" alt=\"$2\" width=\"\" height=\"\" ${3|loading=\"lazy\" decoding=\"async\"|}$4>"
    ],
    "description": "img with PageSpeed attributes"
  },

  "imgLCP": {
    "prefix": "imglcp",
    "body": [
      "<img src=\"$1\" alt=\"$2\" width=\"\" height=\"\" fetchpriority=\"high\"$4>"
    ],
    "description": "img with PageSpeed attributes"
  },

  "script": {
    "prefix": "script",
    "body": [
      "<script type=\"module\" src=\"$1\"$2></script>"
    ],
    "description": "script with defer"
  },

  "placehold": {
    "prefix": "placehold",
    "description": "ダミー画像",
    "body": [
      "<img src=\"https://placehold.jp/999999/ffffff/300x300.jpg\" alt=\"\">"
    ]
  }
}