				<key>ActionBundlePath</key>
				<string>/System/Library/Automator/Run AppleScript.action</string>
				<key>ActionName</key>
				<string>AppleScriptを実行</string>
				<key>ActionParameters</key>
				<dict>
					<key>source</key>
					<string>tell application "System Preferences"	activate	set current pane to pane "com.apple.preference.mouse"end telltell application "System Events"	tell process "System Preferences"		tell window 1			tell group 1				repeat 2 times					click checkbox "スクロール"				end repeat			end tell		end tell	end tellend telltell application "System Preferences" to quit</string>
				</dict>
