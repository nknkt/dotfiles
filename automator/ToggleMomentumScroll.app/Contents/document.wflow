				<key>ActionBundlePath</key>
				<string>/System/Library/Automator/Run Shell Script.action</string>
				<key>ActionName</key>
				<string>シェルスクリプトを実行</string>
				<key>ActionParameters</key>
				<dict>
					<key>COMMAND_STRING</key>
					<string>echo $1
if [ $1 == "0" ]
then
defaults write com.apple.driver.AppleBluetoothMultitouch.mouse MouseMomentumScroll -bool true
echo "ON"
else
defaults write com.apple.driver.AppleBluetoothMultitouch.mouse MouseMomentumScroll -bool false
echo "OFF"
fi</string>
